# Groq API — FREE tier, recommended (https://console.groq.com)
GROQ_API_KEY=

# Prefer Groq when both keys are set
API_PROVIDER=groq

# xAI Grok — requires paid credits on your team (https://console.x.ai)
# GROK_API_KEY=

# Optional: override the default model for your provider
# SUMMARY_MODEL=grok-4.3

# Pinecone (optional — semantic retrieval is skipped if not configured)
PINECONE_API_KEY=
PINECONE_ENV=
PINECONE_INDEX=summary-index
